# --- Core ---
DB_URL=sqlite:///kaljuvee_chat.db
APP_SECRET=change-me-to-a-random-secret
APP_BASE_URL=https://kaljuvee.chat
PORT=5011
FREE_QUERY_LIMIT=3

# --- LLM provider: "xai" (Grok, default), "openai", or "anthropic" ---
LLM_PROVIDER=xai
XAI_API_KEY=
GROK_MODEL=grok-4-1-fast-reasoning
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=          # requires: pip install langchain-anthropic
# ANTHROPIC_MODEL=claude-sonnet-5

# --- Optional: Voice mode (x.ai realtime agent; uses XAI_API_KEY) ---
# XAI_VOICE_AGENT_ID=agent_l6fdLgMIrlHoNcnY

# --- Optional: "Book a call" link (chat intercept + left-menu button) ---
# BOOKING_URL=https://cal.com/kaljuvee

# --- Optional: Google OAuth sign-in ---
# Authorized redirect URI to register in Google Cloud Console:
#   <SERVICE_URL>/auth/google/callback   (e.g. https://kaljuvee.chat/auth/google/callback)
#   http://localhost:5011/auth/google/callback   (for local testing)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Optional: transactional email (Postmark) for verify/reset ---
# POSTMARK_API_TOKEN=
# FROM_EMAIL=info@kaljuvee.chat
